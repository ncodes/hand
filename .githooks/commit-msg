#!/usr/bin/env sh
set -eu

message_file="${1:-}"
if [ -z "$message_file" ] || [ ! -f "$message_file" ]; then
	echo "commit-msg: missing commit message file" >&2
	exit 1
fi

subject="$(sed '/^[[:space:]]*#/d; /^[[:space:]]*$/d; q' "$message_file" | tr -d '\r')"
body="$(sed '/^[[:space:]]*#/d' "$message_file" | tr -d '\r')"

if [ -z "$subject" ]; then
	echo "commit-msg: commit title is required" >&2
	exit 1
fi

case "$subject" in
	merge\ *|Merge\ *|revert\ *|Revert\ *)
		exit 0
		;;
esac

subject_len="$(printf '%s' "$subject" | wc -c | tr -d ' ')"
if [ "$subject_len" -gt 72 ]; then
	echo "commit-msg: title must be 72 characters or fewer" >&2
	exit 1
fi

if ! printf '%s\n' "$subject" | grep -Eq '^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([A-Za-z0-9._/-]+\))?!?: .+'; then
	echo "commit-msg: title must use Conventional Commits, e.g. feat(cli): add config get" >&2
	exit 1
fi

if printf '%s\n' "$subject" | grep -Eq '^[^:]+: [[:upper:]]'; then
	echo "commit-msg: conventional commit description must start lowercase" >&2
	exit 1
fi

description="$(printf '%s\n' "$subject" | sed -E 's/^[^:]+: //')"
case "$description" in
	*.|*,|*';'|*:)
		echo "commit-msg: conventional commit description must not end with punctuation" >&2
		exit 1
		;;
esac

if printf '%s\n' "$body" | grep -Eiq '(^|[[:space:]])co-authored-by[[:space:]]*:'; then
	echo "commit-msg: co-author trailers are not allowed in this repository" >&2
	exit 1
fi

if printf '%s\n' "$body" | grep -Eiq 'codex|generated by|ai assistant|openai'; then
	echo "commit-msg: do not mention assistant/tool attribution in commit messages" >&2
	exit 1
fi

if ! printf '%s\n' "$body" | awk '
BEGIN {
	section_count = 0
	bullet_count = 0
	in_section = 0
	failed = 0
}
NR == 1 {
	next
}
/^[[:space:]]*$/ {
	next
}
/^[[:alnum:]][[:alnum:] _\/-]*:$/ {
	if (in_section && bullet_count == 0) {
		printf "commit-msg: section \"%s\" must include at least one bullet point\n", section_name > "/dev/stderr"
		failed = 1
		exit 1
	}
	in_section = 1
	section_count++
	section_name = $0
	bullet_count = 0
	next
}
{
	if (!in_section) {
		print "commit-msg: body must start with a section heading, e.g. Changed:" > "/dev/stderr"
		failed = 1
		exit 1
	}
	if ($0 ~ /^- [^[:space:]].*/) {
		bullet_count++
		next
	}
	if ($0 ~ /^[[:space:]]*-/) {
		print "commit-msg: bullet points must use \"- \" followed by text" > "/dev/stderr"
		failed = 1
		exit 1
	}
	next
}
END {
	if (failed) {
		exit 1
	}
	if (section_count == 0) {
		print "commit-msg: body must include at least one section heading, e.g. Changed:" > "/dev/stderr"
		exit 1
	}
	if (in_section && bullet_count == 0) {
		printf "commit-msg: section \"%s\" must include at least one bullet point\n", section_name > "/dev/stderr"
		exit 1
	}
}
'; then
	exit 1
fi
