# NAME=Daemon
# MODEL=qwen/qwen3.5-27b
# MODEL_SUMMARY=
# MODEL_CONTEXT_LENGTH=128000
# MODEL_VERIFY_MODEL=true
# MODEL_PROVIDER=openrouter
# MODEL_KEY=replace-with-your-model-key
# OPENAI_API_KEY=replace-with-your-openai-key
# OPENROUTER_API_KEY=replace-with-your-openrouter-key
# MODEL_BASE_URL=https://openrouter.ai/api/v1
# MODEL_API_MODE=chat-completions
# RPC_ADDRESS=127.0.0.1
# RPC_PORT=50051
# MAX_ITERATIONS=90
# LOG_LEVEL=info
# LOG_NO_COLOR=false
# DEBUG_REQUESTS=false
# DEBUG_TRACES=false
# DEBUG_TRACE_DIR=.hand/traces
# RULES_FILES=/absolute/path/to/hand.md,/absolute/path/to/agents.md
# INSTRUCT=
# PLATFORM=cli
# AGENT_FS_ROOTS=/absolute/path/to/workspace,/absolute/path/to/shared-dir
# AGENT_CAP_FS=true
# AGENT_CAP_NET=true
# AGENT_CAP_EXEC=true
# AGENT_CAP_MEM=true
# AGENT_CAP_BROWSER=false
# AGENT_EXEC_ALLOW=
# AGENT_EXEC_ASK=
# AGENT_EXEC_DENY=
# AGENT_STORAGE_BACKEND=sqlite
# AGENT_SESSION_DEFAULT_IDLE_EXPIRY=24h
# AGENT_SESSION_ARCHIVE_RETENTION=720h
# AGENT_COMPACTION_ENABLED=true
# AGENT_COMPACTION_TRIGGER_PERCENT=0.85
# AGENT_COMPACTION_WARN_PERCENT=0.95
